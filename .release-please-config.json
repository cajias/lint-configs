{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "bootstrap-sha": "a4aab214f70829ddeca5702ba4860268d96052b5",
  "packages": {
    "python": {
      "release-type": "python",
      "package-name": "sca-skills",
      "changelog-path": "python/CHANGELOG.md",
      "extra-files": ["pyproject.toml"]
    },
    "typescript": {
      "release-type": "node",
      "package-name": "@cajias/eslint-config",
      "changelog-path": "typescript/CHANGELOG.md"
    },
    "markdown": {
      "release-type": "node",
      "package-name": "@cajias/markdownlint-config",
      "changelog-path": "markdown/CHANGELOG.md"
    },
    "rust": {
      "release-type": "rust",
      "package-name": "cajias-lint-configs",
      "changelog-path": "rust/CHANGELOG.md"
    }
  },
  "plugins": [
    {
      "type": "node-workspace"
    }
  ],
  "separate-pull-requests": true,
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance Improvements" },
    { "type": "revert", "section": "Reverts" },
    { "type": "docs", "section": "Documentation" },
    { "type": "style", "section": "Styles" },
    { "type": "chore", "section": "Miscellaneous" },
    { "type": "refactor", "section": "Code Refactoring" },
    { "type": "test", "section": "Tests" },
    { "type": "build", "section": "Build System" },
    { "type": "ci", "section": "CI/CD" }
  ]
}
